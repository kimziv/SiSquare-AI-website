# SiSquare AI Website Environment Variables
# ==========================================
# ⚠️  WARNING: NEVER commit real credentials or secrets!
# Copy this file to .env.local and fill in your actual values.
# .env.local is already in .gitignore and won't be committed.

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://sisquare.ai
NEXT_PUBLIC_SITE_NAME=SiSquare AI

# API Keys (Add your actual keys in .env.local)
OPENAI_API_KEY=sk-your-api-key-here
RESEND_API_KEY=re_your-api-key-here

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx

# Email Configuration
CONTACT_EMAIL=hello@sisquare.ai

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CONTACT_FORM=true
